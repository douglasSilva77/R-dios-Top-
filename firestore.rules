// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: radio_stations
// Document ID: auto-generated
// Fields:
//   - name: string (required, 1-100 chars)
//   - streamingUrl: string (required, valid URL)
//   - imageUrl: string (required, valid URL)
//   - city: string (required, 1-100 chars)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidRadioStation(data) {
      return hasRequiredFields(['name', 'streamingUrl', 'imageUrl', 'city', 'createdAt']) &&
             hasOnlyAllowedFields(['name', 'streamingUrl', 'imageUrl', 'city', 'genre', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.city is string && data.city.size() > 0 && data.city.size() <= 100 &&
             isValidUrl(data.streamingUrl) &&
             isValidUrl(data.imageUrl) &&
             (!('genre' in data) || (data.genre is string && data.genre.size() <= 50)) &&
             data.createdAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /radio_stations/{stationId} {
      // Public access as requested (no login)
      allow read: if true;
      allow create: if isValidRadioStation(request.resource.data);
      
      // Update/Delete allowed for admin operations (client-side password protected)
      allow update: if isValidRadioStation(request.resource.data);
      allow delete: if true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
